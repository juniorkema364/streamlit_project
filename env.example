# .env.example
# Copiez ce fichier en ".env" et renseignez vos vraies valeurs.
# Ne JAMAIS committer le fichier ".env" réel (voir .gitignore).

# URL de connexion à votre base Upstash Redis.
# Récupérable sur https://console.upstash.com -> votre base -> "Redis Connect" -> "TLS URL"
# Format : rediss://default:<password>@<host>:<port>
REDIS_URL=votre_url_upstash_ici
